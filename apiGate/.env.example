PORT=8080
JWT_SECRET=replace-with-long-random
JWT_EXPIRES_SEC=3600

# coreQ BFF (proxied as /api/v1/core/* → /api/v1/*)
CORE_BACKEND_URL=http://localhost:4000

# authQ — JWT mint (must match CITYQ_INTERNAL_KEY on authQ)
AUTHQ_URL=http://localhost:4100
CITYQ_INTERNAL_KEY=cityq-dev-internal-change-me

# ERPNext (Frappe) — server-side integration user; never expose to browser
ERPNEXT_URL=https://your-site.frappe.cloud
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
# Frappe desk path for CRM sidebar iframe (apiGate /api/v1/portal/menu)
ERPNEXT_CRM_PATH=/app/crm

# crmQ DocType discovery without listing DocType in ERP_ACCESS_MAP (still requires ERP routes on)
ERP_ALLOW_DOCTYPE_DISCOVERY=0

# Per-partner rate limits (requests / minute, in addition to global RATE_LIMIT_MAX)
ERP_PARTNER_RATE_MAX=600
PAYMENT_PARTNER_RATE_MAX=120

# Zoho OAuth — token validation (userinfo)
# Use the same “accounts” host your app uses: .com / .eu / .in / .com.au
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com
ZOHO_USERINFO_PATH=/oauth/user/info

# Gateway-side DocType allowlist (JWT claims). ERPNext still enforces Role Permissions for the API user.
# Comma-separated default when user not in map:
ERP_DEFAULT_DOCTYPES=Customer,Item,Sales Order
# Optional JSON: { "user@corp.com": ["Customer","Item"], "*": ["*"] }
# ERP_ACCESS_MAP_JSON=

# If 1, put user email in JWT for future per-user Frappe impersonation (not wired yet)
ERPNEXT_USER_EMAIL_FROM_ZOHO=0
