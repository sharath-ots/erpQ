{
  "name": "@cityq/apigate",
  "version": "0.1.0",
  "private": true,
  "description": "apiGate — gateway library + optional standalone proxy (Node.js Fastify)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "dev": "node scripts/copy-frappe.mjs && node --watch src/server.js",
    "build": "node scripts/copy-frappe.mjs && node scripts/sync-dist.mjs",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/http-proxy": "^10.0.1",
    "@fastify/jwt": "^9.0.2",
    "@fastify/rate-limit": "^10.1.1",
    "amqplib": "^0.10.4",
    "fastify": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0"
  }
}
