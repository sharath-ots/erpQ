# =============================================================================
# Production environment for: docker-compose.production.yml  +  ./deploy.sh
#
#   cp .env.production.example .env.production
#   Edit .env.production (secrets, PUBLIC_HOST, GHCR_*, APP_VERSION). Never commit it.
#
# Rules that avoid “erpq.lan” / login failures:
# - PUBLIC_HOST = hostname or IP the *browser* uses (must resolve on user machines).
# - NEXT_PUBLIC_* = full URLs the *browser* calls (scheme + host + port). They are passed
#   into auth-web at container start and injected at runtime (AUTH_WEB_RUNTIME_* in compose).
# - Do not use internal-only names (e.g. *.lan) unless every client has DNS/hosts for them.
# =============================================================================

# --- 1. How browsers reach this server (no path, no trailing slash) ------------
# Your public portal hostname (DNS A record should point here).
PUBLIC_HOST=cityqerp.ortusolis.in
# SSL is terminated by Traefik on :443.
PUBLIC_SCHEME=https

# Optional helper (not read by compose; for your own docs/scripts).
# PUBLIC_ORIGIN=${PUBLIC_SCHEME}://${PUBLIC_HOST}

# --- 2. GHCR images (must match build-and-push.ps1 / CI) -----------------------
GHCR_OWNER=sharath-ots
GHCR_PREFIX=erpq
APP_VERSION=latest

# --- 3. Browser URLs (single-host, path-based routing behind Traefik) ----------
# Portal UI:
NEXT_PUBLIC_COMDASH_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}
# Login UI:
NEXT_PUBLIC_AUTH_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}/login
# API Gateway (apiGate):
NEXT_PUBLIC_APIGATE_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}/api
# Auth API (AuthQ):
NEXT_PUBLIC_AUTHQ_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}/auth

# --- 4. AuthQ (auth service) — public URL and OAuth redirects ------------------
# Auth service is exposed at: https://<PUBLIC_HOST>/auth  (Traefik strips /auth before proxying)
AUTHQ_PUBLIC_BASE_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}/auth
AUTHQ_OAUTH_RETURN_URL_PREFIXES=${PUBLIC_SCHEME}://${PUBLIC_HOST}
AUTHQ_OAUTH_DEFAULT_RETURN_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}/
AUTHQ_OAUTH_DEFAULT_ALLOWED_DOC_TYPES=*

AUTHQ_GOOGLE_CLIENT_ID=
AUTHQ_GOOGLE_CLIENT_SECRET=
AUTHQ_GOOGLE_REDIRECT_URI=${AUTHQ_PUBLIC_BASE_URL}/oauth/google/callback

AUTHQ_ZOHO_CLIENT_ID=
AUTHQ_ZOHO_CLIENT_SECRET=
AUTHQ_ZOHO_REDIRECT_URI=${AUTHQ_PUBLIC_BASE_URL}/oauth/zoho/callback
AUTHQ_ZOHO_ACCOUNTS_HOST=accounts.zoho.com

# --- 5. Shared secrets (change in production) ----------------------------------
JWT_SECRET=change-me-long-random-string
CITYQ_INTERNAL_KEY=change-me-another-long-random-string

# --- 6. RabbitMQ (user/pass must match CITYQ_MQ_URL) ---------------------------
RABBITMQ_DEFAULT_USER=erpq
RABBITMQ_DEFAULT_PASS=change-me-strong-password
CITYQ_MQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672

# --- 7. ERPNext (apigate + comdash) --------------------------------------------
# Server-side URL to ERPNext/Frappe (what apiGate calls). This is NOT the portal host if
# you are repurposing `cityqerp.ortusolis.in` for the portal UI.
ERPNEXT_URL=
# URL the *browser* uses for ERP/iframes (if you expose `erp-proxy` via Traefik path routing).
# If you do not use erp-proxy, leave this blank and/or set it to your ERPNext public URL.
ERPNEXT_PUBLIC_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}/erp
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_CRM_PATH=/app/crm
ERPNEXT_IFRAME_QUERY=
ERP_ALLOW_DOCTYPE_DISCOVERY=0
ERP_PARTNER_RATE_MAX=600
PAYMENT_PARTNER_RATE_MAX=120
ERP_DEFAULT_DOCTYPES=Lead,Opportunity,Customer,Contact,DocType,Quotation

# If the host OS maps your ERP hostname to loopback (127.0.0.1 / 127.0.1.1), Docker copies that into
# containers and breaks HTTPS upstreams + apiGate ERP login. These two vars drive Compose `extra_hosts`
# overrides for `apigate`, `comdash`, and `erp-proxy` (container /etc/hosts only — not the host file).
ERPNEXT_PUBLIC_HOSTNAME=cityqerp.ortusolis.in
ERPNEXT_ROUTE_IP=82.29.181.92

# --- 8. Core / portal feature flags --------------------------------------------
CITYQ_MODULE_ERP=1
CITYQ_MODULE_CRM=1
CITYQ_PORTAL_HRQ=1
CITYQ_PORTAL_PURQ=1

# --- 9. auth-web (optional; defaults are safe) ---------------------------------
NEXT_PUBLIC_LOGIN_DEV_BYPASS=false
NEXT_PUBLIC_ERPNEXT_SITE_LABEL=ERPNext
# If auth-web is served under a path prefix (advanced): e.g. AUTH_WEB_ASSET_PREFIX=/login
AUTH_WEB_ASSET_PREFIX=

# --- 10. nginx-proxy profile only (Host-based routing) -------------------------
# Leave empty unless you run: docker compose --profile proxy ...
# Use real DNS names that resolve for clients, not placeholder *.local.
NGINX_PROXY_HTTP_PORT=8081
VIRTUAL_HOST_MQ=
VIRTUAL_HOST_CORE=
VIRTUAL_HOST_AUTH=
VIRTUAL_HOST_API=
VIRTUAL_HOST_DASHBOARD=

# --- 11. Traefik (HTTPS edge) --------------------------------------------------
# Required for Let's Encrypt (ACME HTTP-01).
TRAEFIK_ACME_EMAIL=sharathgt@gmail.com
# Routers in docker-compose.traefik.yml reference this resolver name.
TRAEFIK_CERTRESOLVER=le
# Optional: INFO | DEBUG
TRAEFIK_LOG_LEVEL=INFO

# =============================================================================
# Optional overrides (uncomment and edit only if needed)
# =============================================================================
#
# Host publish ports (if defaults are already in use on the server):
# CORE_PUBLISH_PORT=14000
# AUTH_PUBLISH_PORT=14100
# AUTH_WEB_PUBLISH_PORT=3100
# APIGATE_PUBLISH_PORT=18080
# COMDASH_PUBLISH_PORT=13001
# ERP_PROXY_PUBLISH_PORT=13002
# RABBITMQ_PUBLISH_AMQP=5672
# RABBITMQ_PUBLISH_UI=15672
#
# If you change any *_PUBLISH_PORT above, update NEXT_PUBLIC_* / AUTHQ_* ports to match.
#
# Custom image refs (defaults: ghcr.io/${GHCR_OWNER}/${GHCR_PREFIX}-<service>:${APP_VERSION}):
# CORE_IMAGE=ghcr.io/owner/erpq-core:1.0.0
# AUTH_IMAGE=ghcr.io/owner/erpq-auth:1.0.0
# AUTH_WEB_IMAGE=ghcr.io/owner/erpq-auth-web:1.0.0
# APIGATE_IMAGE=ghcr.io/owner/erpq-apigate:1.0.0
# COMDASH_IMAGE=ghcr.io/owner/erpq-comdash:1.0.0
# ERP_PROXY_IMAGE=ghcr.io/owner/erpq-erp-proxy:1.0.0
# RABBITMQ_IMAGE=rabbitmq:3.13-management-alpine
# NGINX_PROXY_IMAGE=nginxproxy/nginx-proxy:latest
#
# HTTPS on standard ports (443) behind a reverse proxy:
#   Set PUBLIC_SCHEME=https and PUBLIC_HOST to the public hostname (no :port in host if 443).
#   Set NEXT_PUBLIC_* to the same origin your proxy exposes (may omit ports).
#
# OAuth: if users hit both http and https during migration, extend:
#   AUTHQ_OAUTH_RETURN_URL_PREFIXES=https://app.example.com,http://app.example.com
