# Copy this file to `.env` for local development.
# Use with: docker compose up -d --build   (docker-compose.yml)
#
# Production deployments use `.env.production` instead — see `.env.production.example`.

PUBLIC_HOST=localhost
PUBLIC_SCHEME=http
PUBLIC_ORIGIN=${PUBLIC_SCHEME}://${PUBLIC_HOST}

# Optional: only needed when running build-and-push.ps1 if compose interpolates these.
GHCR_OWNER=your-github-org-or-user
GHCR_PREFIX=erpq
APP_VERSION=latest

NEXT_PUBLIC_AUTH_URL=http://${PUBLIC_HOST}:3100
NEXT_PUBLIC_APIGATE_URL=http://${PUBLIC_HOST}:18080
NEXT_PUBLIC_COMDASH_URL=http://${PUBLIC_HOST}:13000
NEXT_PUBLIC_AUTHQ_URL=http://${PUBLIC_HOST}:14100

AUTHQ_PUBLIC_BASE_URL=http://${PUBLIC_HOST}:14100
AUTHQ_OAUTH_RETURN_URL_PREFIXES=http://${PUBLIC_HOST}:13000,http://127.0.0.1:13000
AUTHQ_OAUTH_DEFAULT_RETURN_URL=http://${PUBLIC_HOST}:13000/
AUTHQ_OAUTH_DEFAULT_ALLOWED_DOC_TYPES=*

JWT_SECRET=change-me-dev-only
CITYQ_INTERNAL_KEY=change-me-dev-only
AUTHQ_GOOGLE_CLIENT_ID=
AUTHQ_GOOGLE_CLIENT_SECRET=
AUTHQ_GOOGLE_REDIRECT_URI=${AUTHQ_PUBLIC_BASE_URL}/oauth/google/callback
AUTHQ_ZOHO_CLIENT_ID=
AUTHQ_ZOHO_CLIENT_SECRET=
AUTHQ_ZOHO_REDIRECT_URI=${AUTHQ_PUBLIC_BASE_URL}/oauth/zoho/callback
AUTHQ_ZOHO_ACCOUNTS_HOST=accounts.zoho.com

RABBITMQ_DEFAULT_USER=erpq
RABBITMQ_DEFAULT_PASS=erpq_dev_change_me
CITYQ_MQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672

ERPNEXT_ENABLED=1
ERPNEXT_URL=
ERPNEXT_PUBLIC_URL=http://${PUBLIC_HOST}:13002
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_CRM_PATH=/app/crm
ERPNEXT_IFRAME_QUERY=
ERP_ALLOW_DOCTYPE_DISCOVERY=0
ERP_PARTNER_RATE_MAX=600
PAYMENT_PARTNER_RATE_MAX=120
ERP_DEFAULT_DOCTYPES=Lead,Opportunity,Customer,Contact,DocType,Quotation

CITYQ_MODULE_ERP=1
CITYQ_MODULE_CRM=1
CITYQ_PORTAL_HRQ=1
CITYQ_PORTAL_PURQ=1

NGINX_PROXY_HTTP_PORT=8081

# Blank unless using --profile proxy (avoids Compose unset-variable warnings).
VIRTUAL_HOST_MQ=
VIRTUAL_HOST_CORE=
VIRTUAL_HOST_AUTH=
VIRTUAL_HOST_API=
VIRTUAL_HOST_DASHBOARD=
