# =============================================================================
# Local environment for: docker-compose.yml
#
#   cp .env.example .env
#   Edit .env for your machine. Production deployments use .env.production.
#
# Keep this file structurally aligned with .env.production.example so builds made
# from docker-compose.yml and deployments made from docker-compose.production.yml
# use the same variable names.
# =============================================================================

# --- 1. How browsers reach this local stack (no path, no trailing slash) --------
PUBLIC_HOST=localhost
PUBLIC_SCHEME=http

# Optional helper (not read by compose; for your own docs/scripts).
# PUBLIC_ORIGIN=${PUBLIC_SCHEME}://${PUBLIC_HOST}

# --- 2. GHCR images (used by build-and-push.ps1 / CI) --------------------------
GHCR_OWNER=sharath-ots
GHCR_PREFIX=erpq
APP_VERSION=latest

# --- 3. Browser URLs (local port-based routing) --------------------------------
# Portal UI:
NEXT_PUBLIC_COMDASH_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:13001
# Login UI:
NEXT_PUBLIC_AUTH_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:3100
# API Gateway (apiGate):
NEXT_PUBLIC_APIGATE_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:18080
# Auth API (AuthQ):
NEXT_PUBLIC_AUTHQ_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:14100

# --- 4. AuthQ (auth service) - public URL and OAuth redirects -------------------
AUTHQ_PUBLIC_BASE_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:14100
AUTHQ_OAUTH_RETURN_URL_PREFIXES=${PUBLIC_SCHEME}://${PUBLIC_HOST}:13001,${PUBLIC_SCHEME}://127.0.0.1:13001
AUTHQ_OAUTH_DEFAULT_RETURN_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:13001/
AUTHQ_OAUTH_DEFAULT_ALLOWED_DOC_TYPES=*

AUTHQ_GOOGLE_CLIENT_ID=
AUTHQ_GOOGLE_CLIENT_SECRET=
AUTHQ_GOOGLE_REDIRECT_URI=${AUTHQ_PUBLIC_BASE_URL}/oauth/google/callback

AUTHQ_ZOHO_CLIENT_ID=
AUTHQ_ZOHO_CLIENT_SECRET=
AUTHQ_ZOHO_REDIRECT_URI=${AUTHQ_PUBLIC_BASE_URL}/oauth/zoho/callback
AUTHQ_ZOHO_ACCOUNTS_HOST=accounts.zoho.com

# --- 5. Shared secrets (local defaults only; change for shared environments) ----
JWT_SECRET=change-me-dev-only
CITYQ_INTERNAL_KEY=change-me-dev-only

# --- 6. RabbitMQ (user/pass must match CITYQ_MQ_URL) ---------------------------
RABBITMQ_DEFAULT_USER=erpq
RABBITMQ_DEFAULT_PASS=erpq_dev_change_me
CITYQ_MQ_URL=amqp://${RABBITMQ_DEFAULT_USER}:${RABBITMQ_DEFAULT_PASS}@rabbitmq:5672

# --- 7. ERPNext (apigate + comdash) --------------------------------------------
ERPNEXT_URL=cityqerp.ortusolis.in
ERPNEXT_PUBLIC_URL=${PUBLIC_SCHEME}://${PUBLIC_HOST}:13002
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=
ERPNEXT_CRM_PATH=/app/crm
ERPNEXT_IFRAME_QUERY=
ERP_ALLOW_DOCTYPE_DISCOVERY=0
ERP_PARTNER_RATE_MAX=600
PAYMENT_PARTNER_RATE_MAX=120
ERP_DEFAULT_DOCTYPES=Lead,Opportunity,Customer,Contact,DocType,Quotation

# Container-only hosts overrides for apigate, comdash, and erp-proxy.
ERPNEXT_PUBLIC_HOSTNAME=cityqerp.ortusolis.in
ERPNEXT_ROUTE_IP=82.29.181.92

# --- 8. Core / portal feature flags --------------------------------------------
CITYQ_MODULE_ERP=1
CITYQ_MODULE_CRM=1
CITYQ_PORTAL_HRQ=1
CITYQ_PORTAL_PURQ=1

# --- 9. auth-web (optional; defaults are safe) ---------------------------------
NEXT_PUBLIC_LOGIN_DEV_BYPASS=false
NEXT_PUBLIC_ERPNEXT_SITE_LABEL=ERPNext
# Local auth-web is served from the root of :3100. Production may use /login.
AUTH_WEB_ASSET_PREFIX=

# --- 10. Local host ports -------------------------------------------------------
CORE_PUBLISH_PORT=14000
AUTH_PUBLISH_PORT=14100
AUTH_WEB_PUBLISH_PORT=3100
APIGATE_PUBLISH_PORT=18080
COMDASH_PUBLISH_PORT=13001
ERP_PROXY_PUBLISH_PORT=13002
RABBITMQ_PUBLISH_AMQP=5672
RABBITMQ_PUBLISH_UI=15672

# --- 11. nginx-proxy profile only (Host-based routing) -------------------------
NGINX_PROXY_HTTP_PORT=8081
VIRTUAL_HOST_MQ=
VIRTUAL_HOST_CORE=
VIRTUAL_HOST_AUTH=
VIRTUAL_HOST_API=
VIRTUAL_HOST_DASHBOARD=

# --- 12. Traefik (production only; kept for env parity) ------------------------
TRAEFIK_ACME_EMAIL=
TRAEFIK_CERTRESOLVER=le
TRAEFIK_LOG_LEVEL=INFO
